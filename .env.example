# Cadence Environment Variables

# Nomba API (use TEST credentials for sandbox)
NOMBA_ENV=sandbox
NOMBA_ACCOUNT_ID=your_parent_account_id_here
NOMBA_SUB_ACCOUNT_ID=your_sub_account_id_here
NOMBA_CLIENT_ID=your_client_id_here
NOMBA_CLIENT_SECRET=your_client_secret_here

# Nomba Webhook Verification
NOMBA_WEBHOOK_SECRET=your_webhook_signing_key_here

# Database (Supabase)
DATABASE_URL=postgresql://user:password@host:5432/cadence

# App Security
SECRET_KEY=change-this-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Render
PORT=8000
