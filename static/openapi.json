            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PlanCreateRequest": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "amount": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Amount",
            "description": "Amount to charge per interval"
          },
          "currency": {
            "type": "string",
            "maxLength": 3,
            "minLength": 3,
            "title": "Currency",
            "default": "NGN"
          },
          "interval_days": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Interval Days",
            "description": "Plan billing interval in days"
          },
          "trial_days": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Trial Days",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "name",
          "amount",
          "interval_days"
        ],
        "title": "PlanCreateRequest"
      },
      "PlanResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "amount": {
            "type": "number",
            "title": "Amount"
          },
          "currency": {
            "type": "string",
            "title": "Currency"
          },
          "interval_days": {
            "type": "integer",
            "title": "Interval Days"
          },
          "trial_days": {
            "type": "integer",
            "title": "Trial Days"
          },
          "is_active": {
            "type": "boolean",
            "title": "Is Active"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "amount",
          "currency",
          "interval_days",
          "trial_days",
          "is_active"
        ],
        "title": "PlanResponse"
      },
      "SubscriptionCreateRequest": {
        "properties": {
          "plan_id": {
            "type": "string",
            "title": "Plan Id"
          },
          "customer_email": {
            "type": "string",
            "format": "email",
            "title": "Customer Email"
          },
          "customer_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Customer Name"
          },
          "callback_url": {
            "type": "string",
            "title": "Callback Url"
          }
        },
        "type": "object",
        "required": [
          "plan_id",
          "customer_email",
          "callback_url"
        ],
        "title": "SubscriptionCreateRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
